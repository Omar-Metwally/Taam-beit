# ──────────────────────────────────────────────────────────────────────────────
# Ta'am Beit — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=postgres          # Change in production

# ── JWT Authentication ────────────────────────────────────────────────────────
# Must be at least 32 characters — use a strong random string in production
# Generate one: openssl rand -base64 32
JWT_SECRET_KEY=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_KEY_AT_LEAST_32_CHARS

# ── MinIO Object Storage ──────────────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin         # Change in production
MINIO_SECRET_KEY=minioadmin         # Change in production

# ── Frontend build ────────────────────────────────────────────────────────────
# Public URL where MinIO images are served (used by Vite at build time)
VITE_MINIO_PUBLIC_URL=http://localhost:9000
